<?xml version="1.0" encoding="utf-8"?>
<!-- ====================================================================
     L8 - HorizontalScrollView
     Recipe Carousel that scrolls left-to-right, independent of
     the main vertical scroll.
     ==================================================================== -->
<HorizontalScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:scrollbars="none"
    android:clipToPadding="false"
    android:paddingStart="@dimen/spacing_lg"
    android:paddingEnd="@dimen/spacing_lg"
    android:fillViewport="false">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Recipe Card 1: Chicken Biryani -->
        <LinearLayout
            android:layout_width="@dimen/carousel_card_width"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_carousel_card"
            android:elevation="@dimen/elevation_sm">

            <!-- Recipe Image Placeholder -->
            <View
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@drawable/bg_recipe_placeholder" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_sm">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/recipe_biryani_title"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="@dimen/spacing_xs">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_star" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_xxs"
                        android:text="4.8"
                        android:textSize="@dimen/text_small"
                        android:textColor="@color/colorTextSecondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:text="·"
                        android:textSize="@dimen/text_body"
                        android:textColor="@color/colorTextHint" />

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:src="@drawable/ic_timer" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_xxs"
                        android:text="45 min"
                        android:textSize="@dimen/text_small"
                        android:textColor="@color/colorTextSecondary" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Recipe Card 2: Aloo Paratha -->
        <LinearLayout
            android:layout_width="@dimen/carousel_card_width"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_carousel_card"
            android:layout_marginStart="@dimen/spacing_md"
            android:elevation="@dimen/elevation_sm">

            <View
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@drawable/bg_recipe_placeholder" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_sm">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/recipe_paratha_title"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="@dimen/spacing_xs">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_star" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_xxs"
                        android:text="4.6"
                        android:textSize="@dimen/text_small"
                        android:textColor="@color/colorTextSecondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:text="·"
                        android:textSize="@dimen/text_body"
                        android:textColor="@color/colorTextHint" />

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:src="@drawable/ic_timer" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_xxs"
                        android:text="20 min"
                        android:textSize="@dimen/text_small"
                        android:textColor="@color/colorTextSecondary" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Recipe Card 3: Daal Chawal -->
        <LinearLayout
            android:layout_width="@dimen/carousel_card_width"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_carousel_card"
            android:layout_marginStart="@dimen/spacing_md"
            android:elevation="@dimen/elevation_sm">

            <View
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@drawable/bg_recipe_placeholder" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_sm">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/recipe_daal_title"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="@dimen/spacing_xs">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_star" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_xxs"
                        android:text="4.5"
                        android:textSize="@dimen/text_small"
                        android:textColor="@color/colorTextSecondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:text="·"
                        android:textSize="@dimen/text_body"
                        android:textColor="@color/colorTextHint" />

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:src="@drawable/ic_timer" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_xxs"
                        android:text="30 min"
                        android:textSize="@dimen/text_small"
                        android:textColor="@color/colorTextSecondary" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Recipe Card 4: Haleem -->
        <LinearLayout
            android:layout_width="@dimen/carousel_card_width"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_carousel_card"
            android:layout_marginStart="@dimen/spacing_md"
            android:elevation="@dimen/elevation_sm">

            <View
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@drawable/bg_recipe_placeholder" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_sm">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/recipe_haleem_title"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="@dimen/spacing_xs">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_star" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_xxs"
                        android:text="4.9"
                        android:textSize="@dimen/text_small"
                        android:textColor="@color/colorTextSecondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:text="·"
                        android:textSize="@dimen/text_body"
                        android:textColor="@color/colorTextHint" />

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:src="@drawable/ic_timer" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_xxs"
                        android:text="2 hrs"
                        android:textSize="@dimen/text_small"
                        android:textColor="@color/colorTextSecondary" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Recipe Card 5: Chana Chaat -->
        <LinearLayout
            android:layout_width="@dimen/carousel_card_width"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_carousel_card"
            android:layout_marginStart="@dimen/spacing_md"
            android:elevation="@dimen/elevation_sm">

            <View
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@drawable/bg_recipe_placeholder" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_sm">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/recipe_chana_title"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="@dimen/spacing_xs">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_star" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_xxs"
                        android:text="4.3"
                        android:textSize="@dimen/text_small"
                        android:textColor="@color/colorTextSecondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:text="·"
                        android:textSize="@dimen/text_body"
                        android:textColor="@color/colorTextHint" />

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:src="@drawable/ic_timer" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_xxs"
                        android:text="10 min"
                        android:textSize="@dimen/text_small"
                        android:textColor="@color/colorTextSecondary" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</HorizontalScrollView>

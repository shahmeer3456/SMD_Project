<?xml version="1.0" encoding="utf-8"?>
<!-- ====================================================================
     L10 - ConstraintLayout (Flow)
     Tag Cloud using the Flow helper widget to wrap text chips/tags
     to the next line automatically.
     ==================================================================== -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="@dimen/spacing_sm">

    <!-- Flow helper widget: wraps referenced views to next line -->
    <androidx.constraintlayout.helper.widget.Flow
        android:id="@+id/tagFlow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:flow_wrapMode="chain"
        app:flow_horizontalGap="8dp"
        app:flow_verticalGap="8dp"
        app:flow_horizontalStyle="packed"
        app:flow_horizontalBias="0"
        app:constraint_referenced_ids="tagQuick,tagBudget,tagVegetarian,tagIftar,tagSpicy,tagDesi,tagHealthy,tagBreakfast,tagComfort,tagParty,tagStreet,tagLowCal" />

    <!-- Tag Chips -->
    <TextView
        android:id="@+id/tagQuick"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/chip_height"
        android:background="@drawable/bg_chip"
        android:gravity="center"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md"
        android:text="⚡ Quick"
        android:textColor="@color/colorChipText"
        android:textSize="@dimen/text_small"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tagBudget"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/chip_height"
        android:background="@drawable/bg_chip"
        android:gravity="center"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md"
        android:text="💰 Budget"
        android:textColor="@color/colorChipText"
        android:textSize="@dimen/text_small"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tagVegetarian"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/chip_height"
        android:background="@drawable/bg_chip_selected"
        android:gravity="center"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md"
        android:text="🥬 Vegetarian"
        android:textColor="@color/colorChipTextSelected"
        android:textSize="@dimen/text_small"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tagIftar"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/chip_height"
        android:background="@drawable/bg_chip"
        android:gravity="center"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md"
        android:text="🌙 Iftar"
        android:textColor="@color/colorChipText"
        android:textSize="@dimen/text_small"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tagSpicy"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/chip_height"
        android:background="@drawable/bg_chip"
        android:gravity="center"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md"
        android:text="🌶️ Spicy"
        android:textColor="@color/colorChipText"
        android:textSize="@dimen/text_small"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tagDesi"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/chip_height"
        android:background="@drawable/bg_chip"
        android:gravity="center"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md"
        android:text="🍛 Desi"
        android:textColor="@color/colorChipText"
        android:textSize="@dimen/text_small"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tagHealthy"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/chip_height"
        android:background="@drawable/bg_chip"
        android:gravity="center"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md"
        android:text="🥗 Healthy"
        android:textColor="@color/colorChipText"
        android:textSize="@dimen/text_small"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tagBreakfast"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/chip_height"
        android:background="@drawable/bg_chip"
        android:gravity="center"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md"
        android:text="🍳 Breakfast"
        android:textColor="@color/colorChipText"
        android:textSize="@dimen/text_small"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tagComfort"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/chip_height"
        android:background="@drawable/bg_chip_selected"
        android:gravity="center"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md"
        android:text="🫕 Comfort Food"
        android:textColor="@color/colorChipTextSelected"
        android:textSize="@dimen/text_small"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tagParty"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/chip_height"
        android:background="@drawable/bg_chip"
        android:gravity="center"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md"
        android:text="🎉 Party"
        android:textColor="@color/colorChipText"
        android:textSize="@dimen/text_small"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tagStreet"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/chip_height"
        android:background="@drawable/bg_chip"
        android:gravity="center"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md"
        android:text="🥙 Street Food"
        android:textColor="@color/colorChipText"
        android:textSize="@dimen/text_small"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tagLowCal"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/chip_height"
        android:background="@drawable/bg_chip"
        android:gravity="center"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md"
        android:text="🏋️ Low Cal"
        android:textColor="@color/colorChipText"
        android:textSize="@dimen/text_small"
        android:textStyle="bold" />

</androidx.constraintlayout.widget.ConstraintLayout>

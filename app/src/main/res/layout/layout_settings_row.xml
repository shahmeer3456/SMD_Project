<?xml version="1.0" encoding="utf-8"?>
<!-- ====================================================================
     L4 - RelativeLayout
     Legacy Settings Row using RelativeLayout positioning:
     layout_toRightOf, layout_below, layout_alignParentEnd
     ==================================================================== -->
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:padding="@dimen/spacing_lg">

    <!-- Icon on the left -->
    <ImageView
        android:id="@+id/settingsIcon"
        android:layout_width="@dimen/icon_lg"
        android:layout_height="@dimen/icon_lg"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:src="@drawable/ic_notification_toggle"
        android:contentDescription="Settings Icon" />

    <!-- Title positioned to the right of the icon -->
    <TextView
        android:id="@+id/settingsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toRightOf="@id/settingsIcon"
        android:layout_marginStart="@dimen/spacing_lg"
        android:text="@string/settings_notifications"
        android:textColor="@color/colorTextPrimary"
        android:textSize="@dimen/text_subtitle"
        android:textStyle="bold" />

    <!-- Description below the title, also to the right of icon -->
    <TextView
        android:id="@+id/settingsDescription"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toRightOf="@id/settingsIcon"
        android:layout_below="@id/settingsTitle"
        android:layout_marginStart="@dimen/spacing_lg"
        android:layout_marginTop="@dimen/spacing_xxs"
        android:text="@string/settings_notifications_desc"
        android:textColor="@color/colorTextSecondary"
        android:textSize="@dimen/text_small" />

    <!-- Toggle Switch aligned to end (layout_alignParentEnd) -->
    <Switch
        android:id="@+id/settingsToggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:checked="true"
        android:thumbTint="@color/colorPrimary"
        android:trackTint="@color/colorPrimaryLight" />

</RelativeLayout>

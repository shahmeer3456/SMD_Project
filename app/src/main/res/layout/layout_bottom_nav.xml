<?xml version="1.0" encoding="utf-8"?>
<!-- ====================================================================
     L3 - LinearLayout (Weighted)
     Bottom Navigation Bar with 5 equal-width items using layout_weight="1"
     ==================================================================== -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="@dimen/bottom_nav_height"
    android:background="@drawable/bg_bottom_nav"
    android:elevation="@dimen/elevation_lg"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingTop="@dimen/spacing_sm">

    <!-- Tab 1: Home (Active) -->
    <LinearLayout
        android:id="@+id/tab_home"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="@dimen/icon_md"
            android:layout_height="@dimen/icon_md"
            android:src="@drawable/ic_home" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xxs"
            android:text="@string/nav_home"
            android:textColor="@color/colorBottomNavActive"
            android:textSize="@dimen/text_caption"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Tab 2: Search -->
    <LinearLayout
        android:id="@+id/tab_search"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="@dimen/icon_md"
            android:layout_height="@dimen/icon_md"
            android:src="@drawable/ic_search" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xxs"
            android:text="@string/nav_search"
            android:textColor="@color/colorBottomNavInactive"
            android:textSize="@dimen/text_caption" />
    </LinearLayout>

    <!-- Tab 3: Meal Plan -->
    <LinearLayout
        android:id="@+id/tab_meal_plan"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="@dimen/icon_md"
            android:layout_height="@dimen/icon_md"
            android:src="@drawable/ic_meal_plan" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xxs"
            android:text="@string/nav_meal_plan"
            android:textColor="@color/colorBottomNavInactive"
            android:textSize="@dimen/text_caption" />
    </LinearLayout>

    <!-- Tab 4: Cook -->
    <LinearLayout
        android:id="@+id/tab_cook"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="@dimen/icon_md"
            android:layout_height="@dimen/icon_md"
            android:src="@drawable/ic_cook" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xxs"
            android:text="@string/nav_cook"
            android:textColor="@color/colorBottomNavInactive"
            android:textSize="@dimen/text_caption" />
    </LinearLayout>

    <!-- Tab 5: Profile -->
    <LinearLayout
        android:id="@+id/tab_profile"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="@dimen/icon_md"
            android:layout_height="@dimen/icon_md"
            android:src="@drawable/ic_profile" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xxs"
            android:text="@string/nav_profile"
            android:textColor="@color/colorBottomNavInactive"
            android:textSize="@dimen/text_caption" />
    </LinearLayout>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<!-- Recipe Detail Activity - Full recipe view with all details -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header Image Area with Back Button -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="200dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_gradient_header" />

            <!-- Back arrow -->
            <FrameLayout
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="@dimen/spacing_lg"
                android:layout_gravity="top|start"
                android:background="@drawable/bg_badge"
                android:padding="@dimen/spacing_sm">

                <ImageView
                    android:layout_width="@dimen/icon_md"
                    android:layout_height="@dimen/icon_md"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_back_arrow" />
            </FrameLayout>

            <!-- Recipe Name overlay on image -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:padding="@dimen/spacing_lg"
                android:background="@color/semiTransparentBlack">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/recipe_biryani_title"
                    android:textColor="@color/colorTextOnPrimary"
                    android:textSize="@dimen/text_headline"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="@dimen/spacing_xs">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_star" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_xs"
                        android:text="4.8 · 128 reviews"
                        android:textColor="@color/colorTextOnDark"
                        android:textSize="@dimen/text_small" />
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <!-- L2 - Recipe Detail Card with ConstraintLayout -->
        <include
            layout="@layout/layout_recipe_detail_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/spacing_lg" />

        <!-- Ingredients Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:text="@string/recipe_ingredients"
            style="@style/SectionHeader" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="@dimen/spacing_lg"
            android:layout_marginEnd="@dimen/spacing_lg"
            android:layout_marginTop="@dimen/spacing_sm"
            android:background="@drawable/bg_card"
            android:padding="@dimen/spacing_lg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• 500g Basmati Rice (long grain)"
                style="@style/TextStyle.Body" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="• 750g Chicken (bone-in pieces)"
                style="@style/TextStyle.Body" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="• 3 Large Onions (thinly sliced)"
                style="@style/TextStyle.Body" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="• 1 Cup Yogurt (whisked)"
                style="@style/TextStyle.Body" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="• 2 Tbsp Biryani Masala"
                style="@style/TextStyle.Body" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="• 1 tsp Turmeric Powder"
                style="@style/TextStyle.Body" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="• Saffron strands soaked in warm milk"
                style="@style/TextStyle.Body" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="• Fresh Mint &amp; Coriander leaves"
                style="@style/TextStyle.Body" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="• 4 Green Chillies, Ginger-Garlic paste"
                style="@style/TextStyle.Body" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="• Salt, Oil, Ghee to taste"
                style="@style/TextStyle.Body" />
        </LinearLayout>

        <!-- Instructions Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:text="@string/recipe_instructions"
            style="@style/SectionHeader" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="@dimen/spacing_lg"
            android:layout_marginEnd="@dimen/spacing_lg"
            android:layout_marginTop="@dimen/spacing_sm"
            android:background="@drawable/bg_card"
            android:padding="@dimen/spacing_lg">

            <!-- Step 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_button_primary"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="@color/colorTextOnPrimary"
                    android:textSize="@dimen/text_small"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:text="Soak basmati rice in water for 30 minutes. Par-boil with whole spices until 70% cooked. Drain and set aside."
                    style="@style/TextStyle.Body" />
            </LinearLayout>

            <!-- Step 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/spacing_lg">

                <TextView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_button_primary"
                    android:gravity="center"
                    android:text="2"
                    android:textColor="@color/colorTextOnPrimary"
                    android:textSize="@dimen/text_small"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:text="Marinate chicken with yogurt, ginger-garlic paste, biryani masala, turmeric, salt, and half the fried onions. Let sit for 1 hour."
                    style="@style/TextStyle.Body" />
            </LinearLayout>

            <!-- Step 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/spacing_lg">

                <TextView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_button_primary"
                    android:gravity="center"
                    android:text="3"
                    android:textColor="@color/colorTextOnPrimary"
                    android:textSize="@dimen/text_small"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:text="Cook the marinated chicken on medium heat for 15 minutes until half done. Layer rice on top. Add saffron milk, mint, and coriander."
                    style="@style/TextStyle.Body" />
            </LinearLayout>

            <!-- Step 4 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/spacing_lg">

                <TextView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_button_primary"
                    android:gravity="center"
                    android:text="4"
                    android:textColor="@color/colorTextOnPrimary"
                    android:textSize="@dimen/text_small"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:text="Seal pot with foil and lid. Cook on dum (very low heat) for 25 minutes. Let rest for 5 minutes before serving."
                    style="@style/TextStyle.Body" />
            </LinearLayout>
        </LinearLayout>

        <!-- Tags Section with Tag Cloud -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:text="@string/recipe_tags"
            style="@style/SectionHeader" />

        <include
            layout="@layout/layout_tag_cloud"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_lg"
            android:layout_marginEnd="@dimen/spacing_lg"
            android:layout_marginBottom="@dimen/spacing_xxxl" />

    </LinearLayout>
</ScrollView>

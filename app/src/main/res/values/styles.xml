<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base Theme -->
    <style name="Theme.SmartRasoi" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:windowBackground">@color/colorBackground</item>
        <item name="android:statusBarColor">@color/colorPrimaryDark</item>
    </style>

    <!-- Text Styles -->
    <style name="TextStyle.Hero">
        <item name="android:textSize">@dimen/text_hero</item>
        <item name="android:textColor">@color/colorTextOnPrimary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextStyle.Display">
        <item name="android:textSize">@dimen/text_display</item>
        <item name="android:textColor">@color/colorTextPrimary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextStyle.Headline">
        <item name="android:textSize">@dimen/text_headline</item>
        <item name="android:textColor">@color/colorTextPrimary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextStyle.Title">
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:textColor">@color/colorTextPrimary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextStyle.Subtitle">
        <item name="android:textSize">@dimen/text_subtitle</item>
        <item name="android:textColor">@color/colorTextSecondary</item>
    </style>

    <style name="TextStyle.Body">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/colorTextPrimary</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

    <style name="TextStyle.Caption">
        <item name="android:textSize">@dimen/text_small</item>
        <item name="android:textColor">@color/colorTextSecondary</item>
    </style>

    <style name="TextStyle.Label">
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textColor">@color/colorTextAccent</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <!-- Card Styles -->
    <style name="CardStyle">
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:padding">@dimen/spacing_lg</item>
        <item name="android:elevation">@dimen/elevation_sm</item>
    </style>

    <style name="CardStyle.Accent">
        <item name="android:background">@drawable/bg_card_accent</item>
    </style>

    <!-- Button Styles -->
    <style name="ButtonStyle.Primary">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textColor">@color/colorTextOnPrimary</item>
        <item name="android:textSize">@dimen/text_subtitle</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingLeft">@dimen/spacing_xxl</item>
        <item name="android:paddingRight">@dimen/spacing_xxl</item>
        <item name="android:paddingTop">@dimen/spacing_md</item>
        <item name="android:paddingBottom">@dimen/spacing_md</item>
        <item name="android:minHeight">@dimen/button_height</item>
    </style>

    <style name="ButtonStyle.Secondary">
        <item name="android:background">@drawable/bg_button_secondary</item>
        <item name="android:textColor">@color/colorPrimary</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingLeft">@dimen/spacing_xl</item>
        <item name="android:paddingRight">@dimen/spacing_xl</item>
        <item name="android:paddingTop">@dimen/spacing_sm</item>
        <item name="android:paddingBottom">@dimen/spacing_sm</item>
    </style>

    <!-- Divider -->
    <style name="Divider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/divider_height</item>
        <item name="android:background">@color/colorDivider</item>
    </style>

    <!-- Section Header -->
    <style name="SectionHeader">
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:textColor">@color/colorTextPrimary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingLeft">@dimen/spacing_lg</item>
        <item name="android:paddingRight">@dimen/spacing_lg</item>
        <item name="android:paddingTop">@dimen/spacing_xl</item>
        <item name="android:paddingBottom">@dimen/spacing_sm</item>
    </style>
</resources>

<?xml version="1.0" encoding="utf-8"?>
<!-- Breakfast: Sun/egg-like icon -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#FF8A65" />
            <size android:width="48dp" android:height="48dp" />
        </shape>
    </item>
    <item android:top="12dp" android:bottom="12dp"
        android:left="12dp" android:right="12dp">
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
    <item android:top="16dp" android:bottom="16dp"
        android:left="16dp" android:right="16dp">
        <shape android:shape="oval">
            <solid android:color="#FFD600" />
        </shape>
    </item>
</layer-list>

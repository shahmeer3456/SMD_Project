<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Circle background -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#FF6F00" />
        </shape>
    </item>
    <!-- Head -->
    <item
        android:top="15dp"
        android:bottom="45dp"
        android:left="30dp"
        android:right="30dp">
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
    <!-- Body -->
    <item
        android:top="50dp"
        android:left="10dp"
        android:right="10dp"
        android:bottom="-10dp">
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
</layer-list>

<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/colorPrimary" />
            <corners android:radius="@dimen/radius_round" />
            <padding
                android:left="16dp" android:top="8dp"
                android:right="16dp" android:bottom="8dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/colorBackgroundCard" />
            <corners android:radius="@dimen/radius_round" />
            <stroke android:width="1dp" android:color="@color/colorDivider" />
            <padding
                android:left="16dp" android:top="8dp"
                android:right="16dp" android:bottom="8dp" />
        </shape>
    </item>
</selector>

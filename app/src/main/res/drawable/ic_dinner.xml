<?xml version="1.0" encoding="utf-8"?>
<!-- Dinner icon: Bowl shape -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#EF5350" />
            <size android:width="48dp" android:height="48dp" />
        </shape>
    </item>
    <item android:top="18dp" android:bottom="10dp"
        android:left="10dp" android:right="10dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:bottomLeftRadius="20dp"
                android:bottomRightRadius="20dp" />
        </shape>
    </item>
    <item android:top="12dp" android:bottom="28dp"
        android:left="16dp" android:right="16dp">
        <shape android:shape="rectangle">
            <size android:height="3dp" />
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
</layer-list>
